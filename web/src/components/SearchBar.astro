---
import { COUNTRIES } from '../lib/countries.mjs';
const { countries = COUNTRIES } = Astro.props;
---
<div class="bento-panel mb-7 p-4 md:p-5">
  <div class="mb-5 grid gap-4 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
    <div>
      <p class="mb-3 text-xs font-black uppercase tracking-[0.28em] text-emerald-950/55">Type</p>
      <div class="flex flex-wrap gap-2" aria-label="Filter by resource type">
        <button type="button" class="filter-pill is-active" data-type-filter="all" aria-pressed="true">All</button>
        <button type="button" class="filter-pill" data-type-filter="agent" aria-pressed="false">Agent</button>
        <button type="button" class="filter-pill" data-type-filter="skill" aria-pressed="false">Skill</button>
        <button type="button" class="filter-pill" data-type-filter="mcp" aria-pressed="false">MCP</button>
      </div>
    </div>

    <div>
      <label for="country-filter" class="mb-3 block text-xs font-black uppercase tracking-[0.28em] text-emerald-950/55">
        Country
      </label>
      <select
        id="country-filter"
        class="w-full rounded-full border border-emerald-900/10 bg-white/70 px-4 py-3 text-sm font-black text-emerald-950 outline-none transition focus:border-emerald-500/60 focus:bg-white focus:ring-4 focus:ring-emerald-300/25"
      >
        <option value="all">All non-sanctioned countries</option>
        {countries.map((country) => (
          <option value={country.code}>{country.name}</option>
        ))}
      </select>
      <p class="mt-2 text-xs font-semibold text-emerald-950/45">Sanctioned jurisdictions are intentionally excluded.</p>
    </div>
  </div>

  <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <label for="registry-search" class="text-xs font-black uppercase tracking-[0.28em] text-emerald-950/55">
      Search the registry
    </label>
    <span id="search-count" class="text-sm font-bold text-emerald-950/55"></span>
  </div>
  <div class="relative mt-3">
    <input
      type="search"
      id="registry-search"
      placeholder="Search by skill, agent, MCP, jurisdiction, language, or capability..."
      class="w-full rounded-[1.35rem] border border-emerald-900/10 bg-white/70 px-5 py-4 pr-12 text-base font-semibold text-emerald-950 shadow-inner outline-none transition placeholder:text-emerald-950/35 focus:border-emerald-500/60 focus:bg-white focus:ring-4 focus:ring-emerald-300/25"
      autocomplete="off"
    />
    <span class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 text-xl">⌕</span>
  </div>
</div>

<script>
  import { matchesRegistryFilters } from '../lib/filtering.mjs';

  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('registry-search');
    const countrySelect = document.getElementById('country-filter');
    const typeButtons = Array.from(document.querySelectorAll('[data-type-filter]'));
    const cards = Array.from(document.querySelectorAll('[data-search-card]'));
    const count = document.getElementById('search-count');
    const emptyState = document.getElementById('empty-state');

    const currentType = () => {
      const active = typeButtons.find((button) => button.getAttribute('aria-pressed') === 'true');
      return active?.getAttribute('data-type-filter') || 'all';
    };

    const entryFromCard = (card) => ({
      searchText: card.getAttribute('data-search-text') || card.textContent || '',
      collection: card.getAttribute('data-entry-type') || '',
      country: card.getAttribute('data-entry-country') || '',
    });

    const update = () => {
      const filters = {
        query: input?.value || '',
        type: currentType(),
        country: countrySelect?.value || 'all',
      };
      let visible = 0;

      cards.forEach((card) => {
        const match = matchesRegistryFilters(entryFromCard(card), filters);
        card.classList.toggle('hidden', !match);
        if (match) visible += 1;
      });

      if (count) count.textContent = `${visible} result${visible === 1 ? '' : 's'}`;
      if (emptyState) emptyState.classList.toggle('hidden', visible !== 0);
    };

    typeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        typeButtons.forEach((candidate) => {
          const isActive = candidate === button;
          candidate.setAttribute('aria-pressed', String(isActive));
          candidate.classList.toggle('is-active', isActive);
        });
        update();
      });
    });

    input?.addEventListener('input', update);
    countrySelect?.addEventListener('change', update);
    update();
  });
</script>
