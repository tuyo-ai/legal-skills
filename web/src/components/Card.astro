---
const { entry, featured = false } = Astro.props;
const searchText = [
  entry.title,
  entry.description,
  entry.collectionLabel,
  entry.type,
  entry.country,
  entry.language,
  ...(entry.capabilities ?? []),
].join(' ');

const accentClass = entry.collection === 'skills'
  ? 'from-emerald-300/80 via-lime-200/70 to-amber-200/70'
  : entry.collection === 'agents'
    ? 'from-cyan-200/80 via-teal-200/70 to-emerald-200/70'
    : 'from-amber-200/80 via-orange-200/70 to-lime-200/70';
---
<a
  href={entry.href}
  data-search-card
  data-entry-type={entry.collection}
  data-entry-country={entry.country}
  data-search-text={searchText}
  class={`bento-card group relative overflow-hidden p-5 md:p-6 ${featured ? 'md:col-span-2' : ''}`}
>
  <div class={`absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r ${accentClass}`}></div>
  <div class="relative z-10 flex h-full flex-col gap-5">
    <div class="flex items-start justify-between gap-4">
      <span class="rounded-full border border-emerald-900/10 bg-white/60 px-3 py-1 text-[11px] font-black uppercase tracking-[0.24em] text-emerald-900 shadow-sm">
        {entry.collectionLabel}
      </span>
      <span class="rounded-full bg-emerald-950/5 px-3 py-1 text-xs font-bold text-emerald-950/60">
        {entry.country} · {entry.language}
      </span>
    </div>

    <div>
      <h3 class="text-2xl font-black tracking-tight text-emerald-950 transition-colors group-hover:text-emerald-700">
        {entry.title}
      </h3>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-emerald-950/68">
        {entry.description}
      </p>
    </div>

    {entry.capabilities?.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {entry.capabilities.slice(0, 3).map((capability) => (
          <span class="rounded-full bg-emerald-900/[0.06] px-3 py-1 text-xs font-semibold text-emerald-950/70">
            {capability}
          </span>
        ))}
      </div>
    )}

    <div class="mt-auto flex items-center justify-between pt-2 text-sm font-black text-emerald-800">
      <span>View details</span>
      <span class="transition-transform group-hover:translate-x-1">→</span>
    </div>
  </div>
</a>
