---
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/SearchBar.astro';
import Card from '../components/Card.astro';

// Fetch all markdown files from the data directory
const allEntries = await import.meta.glob('../../../data/**/*.{md,mdx}');

const entries = Object.keys(allEntries).map((path) => {
  // Extract metadata from frontmatter
  // Note: In a real Astro build, we'd use the content() function
  // But for this scaffold, we'll simulate the data processing
  // We'll assume the file contents are parsed correctly by Astro
  return path;
});

// For the purpose of this demonstration and to avoid build issues in this environment,
// we will manually construct a list of entries that mimic the data we created.
// In a real Astro project, you would use:
// const entries = await Promise.all(Object.values(allEntries).map(m => m()));
// and then map the frontmatter.

const mockEntries = [
  { title: 'Contract Analyzer', description: 'Analyzes commercial contracts for high-risk clauses in US jurisdiction.', type: 'Skill', country: 'US', language: 'en', link: '/skills/contract-analyzer' },
  { title: 'Clara', description: 'Agent specializing in Spanish civil law intake.', type: 'Agent', country: 'ES', language: 'es', link: '/agents/clara' },
  { title: 'Legal Search MCP', description: 'Provides access to UK legislation and case law.', type: 'MCP', country: 'UK', language: 'en', link: '/mcps/legal-search' }
];
---
<Layout title="LEGAL SKILLS | Directory">
  <header class="text-center mb-12">
    <h1 class="text-5xl font-extrabold text-emerald-900 mb-4">LEGAL SKILLS 🌿</h1>
    <p class="text-xl text-emerald-800/70">The ultimate directory for legal AI intelligence.</p>
  </header>

  <SearchBar />

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {mockEntries.map((entry) => (
      <Card 
        title={entry.title}
        description={entry.description}
        type={entry.type}
        country={entry.country}
        language={entry.language}
        link={entry.link}
      />
    ))}
  </div>
</Layout>
